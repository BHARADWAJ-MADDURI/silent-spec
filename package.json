{
  "name": "silent-spec",
  "displayName": "silent-spec",
  "description": "Auto-generates unit tests on file save",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
  "commands": [
    {
      "command": "silent-spec.helloWorld",
      "title": "Hello World"
    },
    {
    "command": "silentspec.setApiKey",
    "title": "SilentSpec: Set API Key"
    }
  ],
  "configuration": {
    "title": "SilentSpec",
    "properties": {
      "silentspec.enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable or disable SilentSpec auto test generation"
      },
      "silentspec.supportedExtensions": {
        "type": "array",
        "default": [".ts", ".tsx", ".js", ".jsx"],
        "description": "List of file extensions that SilentSpec will generate tests for"
      },
      "silentspec.openInSplitPanel": {
        "type": "boolean",
        "default": true,
        "description": "Auto-Open generated test files in a split panel"
      }
    }
  }
},
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
