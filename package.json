{
  "name": "silent-spec",
  "displayName": "silent-spec",
  "description": "Auto-generates unit tests on file save",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "silent-spec.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "silentspec.setApiKey",
        "title": "SilentSpec: Set API Key"
      },
      {
        "command": "silentspec.togglePause",
        "title": "SilentSpec: Toggle Pause"
      }
    ],
    "configuration": {
      "title": "SilentSpec",
      "properties": {
        "silentspec.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable SilentSpec auto test generation"
        },
        "silentspec.supportedExtensions": {
          "type": "array",
          "default": [
            ".ts",
            ".tsx",
            ".js",
            ".jsx"
          ],
          "description": "List of file extensions that SilentSpec will generate tests for"
        },
        "silentspec.openInSplitPanel": {
          "type": "boolean",
          "default": true,
          "description": "Auto-Open generated test files in a split panel"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "jest --runInBand",
    "test:integration": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.13",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "jest": "^30.2.0",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.56.1"
  }
}
