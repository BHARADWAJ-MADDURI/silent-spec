{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node", "jest"],
    "isolatedModules": true,
    "module": "CommonJS",
    "moduleResolution": "node"
  },
  "include": [
    "src/__tests__/**/*.ts",
    "src/utils/**/*.ts",
    "src/ai/**/*.ts",
    "src/*.ts"
  ]
}
